{
  "name": "thekselect-root",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --open /showcase/index.html",
    "build": "npm run build --workspace=packages/thekselect && npm run build --workspace=packages/thekselect-vue --if-present",
    "build:showcase": "vite build --config vite.showcase.config.ts",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.57.0",
    "shx": "^0.4.0",
    "terser": "^5.46.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.0.18"
  }
}
